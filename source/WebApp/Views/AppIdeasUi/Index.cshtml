@using Data.Identity
@using Data.Models
@using Data.Enums
@model WebApp.ViewModels.AppIdeas.AppIdeasIndexVm
@{
    ViewData["Title"] = "App Ideas";
    var appTypes = Enum.GetNames(typeof(AppType));
    var categories = Enum.GetNames(typeof(AppCategory));
    var deleteDisabled = User.IsInRole(Roles.Test) || User.IsInRole(Roles.Standard);
}

<div class="container py-4">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h1 class="h3 mb-0">App Ideas</h1>
    </div>
    <div class="card mb-4">
        <div class="card-header">Create App</div>
        <div class="card-body">
            <form method="post" action="/app-ideas">
                @Html.AntiForgeryToken()
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label">Type</label>
                        <select class="form-select" asp-for="Type">
                            @foreach (var t in appTypes)
                            {
                                <option value="@t">@t</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Category</label>
                        <select class="form-select" asp-for="Category">
                            @foreach (var c in categories)
                            {
                                <option value="@c">@c</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Description</label>
                        <input class="form-control" asp-for="Description" placeholder="Describe the app idea..." />
                    </div>

                    <div class="col-12">
                        <button type="submit" class="btn btn-primary">Create App Idea</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
    <div class="card">
        <div class="card-header"> Existing App Ideas (@Model.AppIdeas.Count)</div>
        <div class="table-responsive">
            <table class="table table-dark table-striped align-middle mb-0">
                <thead>
                    <tr>
                        <th style="width: 140px;">Type</th>
                        <th style="width: 160px;">Category</th>
                        <th>Description</th>
                        <th style="width: 220px;" class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.AppIdeas.Count == 0)
                    {
                        <tr>
                            <td colspan="4" class="text-muted">No app ideas yet. Create one above.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var a in Model.AppIdeas)
                        {
                            <tr>
                                <td>
                                    <code>@a.Type</code>
                                </td>
                                <td>
                                    <code>@a.Category</code>
                                </td>
                                <td>@a.Description</td>
                                <td class="text-end">
                                    @if (a.IsInUse)
                                    {
                                        <span class="badge text-bg-secondary ms-2">In use</span>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#editAppIdeaModal" data-appidea.id="@a.Id" data-type="@a.Type" data-category="@a.Category" data-description="@a.Description">Update</button>
                                        <button type="button" class="btn btn-sm btn-outline-danger" 
                                            data-bs-toggle="modal" 
                                            data-bs-target="#confirmDeleteAppIdeaModal" 
                                            data-appidea-id="@a.Id" 
                                            disabled="@(deleteDisabled)" 
                                            title= @(deleteDisabled ? "This role cannot delete App Ideas" : "Delete this App Idea")
                                        >Delete</button>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Edit App Idea Modal -->
<div class="modal fade" id="editAppIdeaModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Update App Idea</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" id="editAppIdeaForm">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label">Type</label>
                            <select class="form-select" name="type" id="editType">
                                @foreach (var t in appTypes)
                                {
                                    <option value="@t">@t</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Category</label>
                            <select class="form-select" name="category" id="editCategory">
                                @foreach (var c in categories)
                                {
                                    <option value="@c">@c</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Description</label>
                            <input class="form-control" name="description" id="editDescription" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete App Idea modal -->
<div class="modal fade" id="confirmDeleteAppIdeaModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Delete app idea?</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">This will permanently delete the app idea. If it is referenced by any challenges, the deletion may be blocked.</div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <form method="post" id="deleteAppIdeaForm" class="m-0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger">Delete</button>
                    </form>
                </div>
            </div>
        </div>
</div>

@section Scripts {
    <script>
        // Edit modal
        const editModal = document.getElementById('editAppIdeaModal');
        editModal?.addEventListener('show.bs.modal', event => {
            const button = event.relatedTarget;
            const id = button.getAttribute('data-appidea.id');

            document.getElementById('editType').value = button.getAttribute('data-type');
            document.getElementById('editCategory').value = button.getAttribute('data-category');
            document.getElementById('editDescription').value = button.getAttribute('data-description');
            document.getElementById('editAppIdeaForm').action = `/app-ideas/${id}/update`;

        });

        // Delete modal
        const deleteModal = document.getElementById('confirmDeleteAppIdeaModal');
        deleteModal?.addEventListener('show.bs.modal', event => {
            const button = event.relatedTarget;
            const id = button.getAttribute('data-appidea-id');
            document.getElementById('deleteAppIdeaForm').action = `/app-ideas/${id}/delete`;
        });
    </script>
}