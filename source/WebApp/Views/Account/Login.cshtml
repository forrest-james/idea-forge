@model WebApp.ViewModels.Account.LoginVm
@{
    ViewData["Title"] = "Login";
}

<div class="container py-5" style="max-width: 520px;">
    <h1 class="h3 mb-3">Login</h1>
    <form method="post" action="/account/login">
        @Html.AntiForgeryToken()
        <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />

        <div class="mb-3">
            <label class="form-label">Email</label>
            <input class="form-control" asp-for="Email" autocomplete="username" />
            <div class="text-danger small">@Html.ValidationMessageFor(m => m.Email)</div>
        </div>

        <div class="mb-3">
            <label class="form-label">Password</label>
            <input class="form-control" asp-for="Password" autocomplete="current-password" />
            <div class="text-danger small">@Html.ValidationMessageFor(m => m.Password)</div>
        </div>

        <div class="form-check mb-3">
            <input class="form-check-input" asp-for="RememberMe" />
            <label class="form-check-label" asp-for="RememberMe">Remember me</label>
        </div>

        @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div>@err.ErrorMessage</div>
                    }
                </div>
            }
        <button type="submit" class="btn btn-primary w-100">Sign in</button>
    </form>
    <div class="text-center text-muted small mb-2">- or -</div>
    <form method="post" action="/account/login-test">
        @Html.AntiForgeryToken()
        <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
        <button type="submit" class="btn btn-secondary w-100">Test User</button>
    </form>
</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />`
}