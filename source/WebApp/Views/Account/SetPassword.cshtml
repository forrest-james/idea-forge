@model WebApp.ViewModels.Account.SetPasswordVm
@{
    ViewData["Title"] = "Set Password";
}

<div class="container py-5" style="max-width: 520px;">
    <h1 class="h3 mb-3">Set your password</h1>
    <form method="post" action="/account/set-password">
        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="UserId" />
        <input type="hidden" asp-for="Token" />

        <div class="mb-3">
            <label class="form-label">New password</label>
            <input class="form-control" asp-for="Password" autocomplete="new-password" />
            <div class="text-danger small">@Html.ValidationMessageFor(m => m.Password)</div>
        </div>

        <div class="mb-3">
            <label class="form-label">Confirm password</label>
            <input class="form-control" asp-for="ConfirmPassword" autocomplete="new-password" />
            <div class="text-danger small">@Html.ValidationMessageFor(m => m.ConfirmPassword)</div>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@error.ErrorMessage</div>
                }
            </div>   
        }
            <button type="submit" class="btn btn-primary w-100">Set Password</button>
        </form>
</div>