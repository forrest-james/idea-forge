@using Data.Identity
@model WebApp.ViewModels.Palettes.PalettesIndexVm
@{
    ViewData["Title"] = "Palettes";
    var deleteDisabled = User.IsInRole(Roles.Test) || User.IsInRole(Roles.Standard);
}

<div class="container py-4">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h1 class="h3 mb-0">Palettes</h1>
        <form method="post" action="/palettes/random" class="m-0">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-primary">Generate Random Palette</button>
        </form>
    </div>
    <div class="card mb-4">
        <div class="card-header">Create Palette</div>
        <div class="card-body">
            <form method="post" action="/palettes">
                @Html.AntiForgeryToken()
                <div class="row g-3 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label">Primary</label>
                        <div class="d-flex gap-2 align-items-center">
                            <input type="color" class="form-control form-control-color" id="PrimaryColorPicker" value="@Model.PrimaryColor"/>
                            <input type="text" class="form-control" id="PrimaryColorText" asp-for="PrimaryColor" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Secondary</label>
                        <div class="d-flex gap-2 align-items-center">
                            <input type="color" class="form-control form-control-color" id="SecondaryColorPicker" value="@Model.SecondaryColor" />
                            <input type="text" class="form-control" id="SecondaryColorText" asp-for="SecondaryColor" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Accent</label>
                        <div class="d-flex gap-2 align-items-center">
                            <input type="color" class="form-control form-control-color" id="AccentColorPicker" value="@Model.AccentColor" />
                            <input type="text" class="form-control" id="AccentColorText" asp-for="AccentColor" />
                        </div>
                    </div>

                    <div class="col-12">
                        <button type="submit" class="btn btn-primary">Create Palette</button>
                    </div>
                </div>

                <div class="form-text mt-2">Tip: You can type hex values (e.g., #1F2937) or use the color pickers.</div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-header">Existing Palettes (@Model.Palettes.Count)</div>
        <div class="table-responsive">
            <table class="table table-dark table-striped align-middle mb-0">
                <thead>
                    <tr>
                        <th style="width: 140px;">Preview</th>
                        <th>Primary</th>
                        <th>Secondary</th>
                        <th>Accent</th>
                        <th style="width: 180px;" class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Palettes.Count == 0)
                    {
                        <tr>
                            <td colspan="5" class="text-muted">No palettes yet. Create one above or generate random palettes.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var p in Model.Palettes)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex gap-2">
                                        <div title="@p.PrimaryColor" style="width:28px;height:28px;border:1px solid var(--bs-border-color);background:@p.PrimaryColor;"></div>
                                        <div title="@p.SecondaryColor" style="width:28px;height:28px;border:1px solid var(--bs-border-color);background:@p.SecondaryColor;"></div>
                                        <div title="@p.AccentColor" style="width:28px;height:28px;border:1px solid var(--bs-border-color);background:@p.AccentColor;"></div>
                                    </div>
                                </td>
                                <td><code>@p.PrimaryColor</code></td>
                                <td><code>@p.SecondaryColor</code></td>
                                <td><code>@p.AccentColor</code></td>
                                <td class="text-end">                                    
                                    @if (p.IsInUse)
                                    {
                                        <span class="badge text-bg-secondary ms-2">In use</span>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#editPaletteModal" data-palette-id="@p.Id" data-primary="@p.PrimaryColor" data-secondary="@p.SecondaryColor" data-accent="@p.AccentColor">Update</button>
                                        <button type="button" class="btn btn-sm btn-outline-danger"
                                            disabled=@(deleteDisabled)
                                            title=@(deleteDisabled ? "This role cannot delete palettes" : "Delete this palette")
                                            data-bs-toggle="modal" data-bs-target="#confirmDeleteModal" data-palette-id="@p.Id">Delete</button>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
<!-- Edit palette modal -->
<div class="modal fade" id="editPaletteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Update palette</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" id="editPaletteForm">
                @Html.AntiForgeryToken()
                <div class="modal-body">                    
                    <div class="mb-3">
                        <label class="form-label">Primary</label>
                        <div class="d-flex gap-2 align-items-center">
                            <input type="color" class="form-control form-control-color" id="EditPrimaryPicker" value="#000000" />
                            <input type="text" class="form-control" id="EditPrimaryText" name="primaryColor" value="#000000" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Secondary</label>
                        <div class="d-flex gap-2 align-items-center">
                            <input type="color" class="form-control form-control-color" id="EditSecondaryPicker" value="#FFFFFF" />
                            <input type="text" class="form-control" id="EditSecondaryText" name="secondaryColor" value="#FFFFFF" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Accent</label>
                        <div class="d-flex gap-2 align-items-center">
                            <input type="color" class="form-control form-control-color" id="EditAccentPicker" value="#FF0000" />
                            <input type="text" class="form-control" id="EditAccentText" name="accentColor" value="#FF0000" />
                        </div>
                    </div>
                    <div class="form-text">Tip: You can type hex values (e.g., #1F2937) or use the color pickers.</div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save changes</button>
                </div>
            </form>
        </div>
    </div>
</div>
<!-- Delete Confirmation Modal -->
<div class="modal fade" id="confirmDeleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Delete palette?</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                This will permanently delete the palette. If it is referenced by any challenge, the deletion may be blocked.
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <form method="post" id="deletePaletteForm" class="m-0">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function wireColorPair(pickerId, textId) {
            const picker = document.getElementById(pickerId);
            const text = document.getElementById(textId);
            if (!picker || !text) return;

            const init = normalizeHex(text.value);
            if (init) picker.value = init;

            picker.addEventListener('input', () => {
                text.value = picker.value.toUpperCase();
            });

            text.addEventListener('input', () => {
                const hex = normalizeHex(text.value);
                if (hex) picker.value = hex;
            });
        }
        function normalizeHex(value) {
            if (!value) return null;

            let v = value.trim();
            if (!v.startsWith('#')) v = '#' + v;
            if (/^#[0-9A-Fa-f]{6}$/.test(v)) return v.toUpperCase();
            return null;
        }
        wireColorPair('PrimaryColorPicker', 'PrimaryColorText');
        wireColorPair('SecondaryColorPicker', 'SecondaryColorText');
        wireColorPair('AccentColorPicker', 'AccentColorText');
        wireColorPair('EditPrimaryPicker', 'EditPrimaryText');
        wireColorPair('EditSecondaryPicker', 'EditSecondaryText');
        wireColorPair('EditAccentPicker', 'EditAccentText');

        // Edit modal
        const editModal = document.getElementById('editPaletteModal');
        editModal?.addEventListener('show.bs.modal', event => {
            const button = event.relatedTarget;
            const id = button.getAttribute('data-palette-id');
            const primary = button.getAttribute('data-primary');
            const secondary = button.getAttribute('data-secondary');
            const accent = button.getAttribute('data-accent');            

            document.getElementById('EditPrimaryText').value = primary;
            document.getElementById('EditSecondaryText').value = secondary;
            document.getElementById('EditAccentText').value = accent;
            document.getElementById('editPaletteForm').action = `/palettes/${id}/update`;

            const p = normalizeHex(primary);
            const s = normalizeHex(secondary);
            const a = normalizeHex(accent);

            if (p) document.getElementById('EditPrimaryPicker').value = p;
            if (s) document.getElementById('EditSecondaryPicker').value = s;
            if (a) document.getElementById('EditAccentPicker').value = a;
        });

        // Delete modal
        const deleteModal = document.getElementById('confirmDeleteModal');
        deleteModal?.addEventListener('show.bs.modal', event => {
            const button = event.relatedTarget;
            const id = button.getAttribute('data-palette-id');
            document.getElementById('deletePaletteForm').action = `/palettes/${id}/delete`;
        });
    </script>
}