@using Data.Identity
@model WebApp.ViewModels.Challenges.ChallengeDetailsVm
@{
    ViewData["Title"] = Model.Name + " - Challenge Details";
    var deleteDisabled = User.IsInRole(Roles.Test) || User.IsInRole(Roles.Standard);
}

<div class="container py-4">
    <div class="d-flex align-items-start justify-content-between mb-3">
        <div>
            <h1 class="h3 mb-0">@Model.Name</h1>
            <div class="text-muted small">@Model.Id</div>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#createSubmissionModal" data-challenge-id="@Model.Id">Add Submission</button>
            <button class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#editChallengeNameModal" data-challenge-id="@Model.Id" data-challenge-name="@Model.Name">Edit Name</button>
            <button class="btn btn-outline-danger" 
                disabled = @(Model.Submissions.Count == 0 && !deleteDisabled) 
                title=@((Model.Submissions.Count == 0 && !deleteDisabled) ? "Delete this challenge" : (Model.Submissions.Count == 0 ? "This role cannot delete Challenges" : "Cannot delete: has submissions")) 
                data-bs-toggle="modal" data-bs-target="#confirmDeleteChallengeModal" data-challenge-id="@Model.Id">Delete</button>
        </div>
    </div>
    <div class="row g-3">
        <div class="col-lg-7">
            <div class="card">
                <div class="card-header">App Idea</div>
                <div class="card-body">
                    <div class="mb-2">
                        <span class="badge text-bg-secondary">@Model.AppType</span>
                        <span class="badge text-bg-secondary">@Model.AppCategory</span>
                    </div>
                    <p class="mb-0">@Model.AppDescription</p>
                </div>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="card">
                <div class="card-header">Palette</div>
                <div class="d-flex gap-2 mt-2 mb-2 justify-content-center">
                    <div title="@Model.PrimaryColor" style="width:44px;height:44px;border:1px solid #ccc;background:@Model.PrimaryColor;"></div>
                    <div title="@Model.SecondaryColor" style="width:44px;height:44px;border:1px solid #ccc;background:@Model.SecondaryColor;"></div>
                    <div title="@Model.AccentColor" style="width:44px;height:44px;border:1px solid #ccc;background:@Model.AccentColor;"></div>
                </div>
                <ul class="mb-0">
                    <li><code>@Model.PrimaryColor</code></li>
                    <li><code>@Model.SecondaryColor</code></li>
                    <li><code>@Model.AccentColor</code></li>
                </ul>
            </div>
        </div>
    </div>
    <div class="card mt-3">
        <div class="card-header">Submissions (@Model.Submissions.Count)</div>
        <div class="table-responsive">
            <table class="table table-striped align-middle mb-0">
                <thead>
                    <tr>
                        <th style="width: 120px;">Images</th>
                        <th>Description</th>
                        <th style="width: 180px;" class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Submissions.Count == 0)
                    {
                        <tr>
                            <td colspan="3" class="text-muted">No submissions yet for this challenge.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var s in Model.Submissions)
                        {
                            <tr>
                                <td><span class="badge text-bg-secondary">@s.ImageCount</span></td>
                                <td>@s.DescriptionPreview</td>
                                <td class="text-end">
                                    <a class="btn btn-sm btn-outline-primary" href="/submissions/@s.Id">View</a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="mt-3">
        <a href="/challenges" class="btn btn-link">← Back to Challenges</a>
    </div>
    <!-- Edit Challenge Name modal -->
    <div class="modal fade" id="editChallengeNameModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Challenge Name</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form method="post" id="renameChallengeForm">
                    @Html.AntiForgeryToken()
                    <div class="modal-body">
                        <div class="mb-2">
                            <label class="form-label">Name</label>
                            <input type="text" class="form-control" name="name" id="challengeNameInput" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <!-- Add Submission modal -->
    <div class="modal fade" id="createSubmissionModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add Submission</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form method="post" id="createSubmissionForm" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <textarea class="form-control" name="Description" rows="5" placeholder="Design thoughts, rationale, constraints, etc."></textarea>
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Images (optional)</label>
                            <input type="file" class="form-control" name="Files" multiple accept=".jpg,.jpeg,.png,.webp" />
                            <div class="form-text">You can create a submission without images and upload later.</div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Submit</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <!-- Delete Challenge modal -->
    <div class="modal fade" id="confirmDeleteChallengeModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Delete challenge?</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">This will permanently delete the challenge. This is only allowed if it has no submissions.</div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <form method="post" id="deleteChallengeForm" class="m-0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger">Delete</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const nameModal = document.getElementById('editChallengeNameModal');
        nameModal?.addEventListener('show.bs.modal', event => {
            const button = event.relatedTarget;
            const id = button.getAttribute('data-challenge-id');
            const name = button.getAttribute('data-challenge-name');

            document.getElementById('challengeNameInput').value = name ?? '';
            document.getElementById('renameChallengeForm').action = `/challenges/${id}/rename`;
        });

        const subModal = document.getElementById('createSubmissionModal');
        subModal?.addEventListener('show.bs.modal', event => {
            const button = event.relatedTarget;
            const id = button.getAttribute('data-challenge-id');
            document.getElementById('createSubmissionForm').action = `/challenges/${id}/submissions`;
        });

        const delModal = document.getElementById('confirmDeleteChallengeModal');
        delModal?.addEventListener('show.bs.modal', event => {
            const button = event.relatedTarget;
            const id = button.getAttribute('data-challenge-id');
            document.getElementById('deleteChallengeForm').action = `/challenges/${id}/delete`;
        });
    </script>
}