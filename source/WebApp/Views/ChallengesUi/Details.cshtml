@model WebApp.ViewModels.Challenges.ChallengeDetailsVm
@{
    ViewData["Title"] = Model.Name + " - Challenge Details"; 
}

<div class="container py-4">
    <div class="d-flex align-items-start justify-content-between mb-3">
        <div>
            <h1 class="h3 mb-0">@Model.Name</h1>
            <div class="text-muted small>">@Model.Id</div>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-primary" disabled>Add Submission</button>
            <button class="btn btn-outline-danger" disabled>Delete Challenge</button>
        </div>
    </div>
    <div class="row g-3">
        <div class="col-lg-7">
            <div class="card">
                <div class="card-header">App Idea</div>
                <div class="card-body">
                    <div class="mb-2">
                        <span class="badge text-bg-secondary">@Model.AppType</span>
                        <span class="badge text-bg-secondary">@Model.AppCategory</span>
                    </div>
                    <p class="mb-0">@Model.AppDescription</p>
                </div>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="card">
                <div class="card-header">Palette</div>
                <div class="d-flex gap-2 mt-2 mb-2 justify-content-center">
                    <div title="@Model.PrimaryColor" style="width:44px;height:44px;border:1px solid #ccc;background:@Model.PrimaryColor;"></div>
                    <div title="@Model.SecondaryColor" style="width:44px;height:44px;border:1px solid #ccc;background:@Model.SecondaryColor;"></div>
                    <div title="@Model.AccentColor" style="width:44px;height:44px;border:1px solid #ccc;background:@Model.AccentColor;"></div>
                </div>
                <ul class="mb-0">
                    <li><code>@Model.PrimaryColor</code></li>
                    <li><code>@Model.SecondaryColor</code></li>
                    <li><code>@Model.AccentColor</code></li>
                </ul>
            </div>
        </div>
    </div>
    <div class="card mt-3">
        <div class="card-header">Submissions (@Model.Submissions.Count)</div>
        <div class="table-responsive">
            <table class="table table-striped align-middle mb-0">
                <thead>
                    <tr>
                        <th style="width: 120px;">Images</th>
                        <th>Description</th>
                        <th style="width: 180px;" class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Submissions.Count == 0)
                    {
                        <tr>
                            <td colspan="3" class="text-muted">No submissions yet for this challenge.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var s in Model.Submissions)
                        {
                            <tr>
                                <td><span class="badge text-bg-secondary">@s.ImageCount</span></td>
                                <td>@s.DescriptionPreview</td>
                                <td class="text-end">
                                    <a class="btn btn-sm btn-outline-primary" href="/submissions/@s.Id">View</a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="mt-3">
        <a href="/challenges" class="btn btn-link">← Back to Challenges</a>
    </div>
</div>