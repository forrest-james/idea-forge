@using Data.Identity

@model WebApp.ViewModels.Challenges.ChallengesIndexVm
@{
    ViewData["Title"] = "Challenges";
    var deleteDisabled = User.IsInRole(Roles.Test) || User.IsInRole(Roles.Standard);
}

<div class="container py-4">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h1 class="h3 mb-0">Challenges</h1>
        <form method="post" action="/challenges/new" class="m-0">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-primary">New</button>
        </form>
    </div>
    <div class="card">
        <div class="card-header">All Challenges (@Model.Challenges.Count)</div>
        <div class="table-responsive">
            <table class="table table-dark table-striped align-middle mb-0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th style="width: 180px;">App Idea</th>
                        <th style="width: 160px;">Palette</th>
                        <th style="width: 200px;" class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Challenges.Count == 0)
                    {
                        <tr>
                            <td colspan="4" class="text-muted">No challenges yet.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var c in Model.Challenges)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@c.Name</div>
                                    <div class="text-muted small">@c.Id</div>
                                </td>
                                <td>
                                    <div><code>@c.AppType</code></div>
                                    <div><code>@c.AppCategory</code></div>
                                </td>
                                <td>
                                    <div class="d-flex gap-2">
                                        <div title="@c.PrimaryColor" style="width:28px;height:28px;border:1px solid var(--bs-border-color);background:@c.PrimaryColor;"></div>
                                        <div title="@c.SecondaryColor" style="width:28px;height:28px;border:1px solid var(--bs-border-color);background:@c.SecondaryColor;"></div>
                                        <div title="@c.AccentColor" style="width:28px;height:28px;border:1px solid var(--bs-border-color);background:@c.AccentColor;"></div>
                                    </div>
                                </td>
                                <td class="text-end">
                                    <a class="btn btn-sm btn-outline-primary" href="/challenges/@c.Id">View</a>
                                    @if(c.IsDeletable)
                                    {
                                        <button class="btn btn-sm btn-outline-danger" 
                                            disabled=@(deleteDisabled)
                                            title=@(deleteDisabled ? "This role cannot delete challenges" : "Delete challenge")  
                                            data-bs-toggle="modal" 
                                            data-bs-target="#confirmDeleteChallengeModal" 
                                            data-challenge-id="@c.Id">Delete</button>
                                    }
                                    else
                                    {
                                        <span class="badge text-bg-secondary ms-2">In use</span>
                                    }
                                    
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="modal fade" id="confirmDeleteChallengeModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Delete challenge?</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">This will permanently delete the challenge. This is only allowed if it has no submissions.</div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <form method="post" id="deleteChallengeForm" class="m-0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger">Delete</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts
{
    <script>
        const delModal = document.getElementById('confirmDeleteChallengeModal');
        delModal?.addEventListener('show.bs.modal', event => {
            const button = event.relatedTarget;
            const id = button.getAttribute('data-challenge-id');
            document.getElementById('deleteChallengeForm').action = `/challenges/${id}/delete`;
        });
    </script>
}