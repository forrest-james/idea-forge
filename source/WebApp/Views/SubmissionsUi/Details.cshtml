@model WebApp.ViewModels.Submissions.SubmissionDetailsVm
@{
    ViewData["Title"] = "Submission for " + Model.ChallengeName;
}

<div class="container py-4">
    <div class="d-flex align-items-start justify-content-between mb-3">
        <div>
            <h1 class="h3 mb-1">Submission for @Model.ChallengeName</h1>
            <div class="text-muted small">@Model.Id</div>
            <div class="mt-2">
                <span class="text-muted">Challenge:</span>
                <a href="/challenges/@Model.ChallengeId" class="link-primary fw-semibold">@Model.ChallengeName</a>
            </div>
        </div>
        <div class="d-flex gap-2">
            @if (Model.Images.Count == 0)
            {
                <button type="button" class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#confirmDeleteSubmissionModal" data-submission-id="@Model.Id">Delete Submission</button>
            }
            <form method="post" action="/submissions/@Model.Id/images" enctype="multipart/form-data" class="d-flex gap-2">
                @Html.AntiForgeryToken()
                <input type="file" name="files" multiple accept=".jpg,.jpeg,.png,.webp" class="form-control" />
                <button type="submit" class="btn btn-primary">Upload</button>
            </form>
        </div>
    </div>
    <div class="card mb-3">
        <div class="card-header">Description</div>
        <div class="card-body">
            @if (string.IsNullOrWhiteSpace(Model.Description))
            {
                <div class="text-muted">No description provided.</div>
            }
            else
            {
                <p class="mb-0">@Model.Description</p>
            }
        </div>
    </div>
    <div class="card">
        <div class="card-header">Images (@Model.Images.Count)</div>
        <div class="card-body">
            @if (Model.Images.Count == 0)
            {
                <div class="text-muted">No images yet.</div>
            }
            else
            {
                <div class="row g-3">
                    @foreach (var img in Model.Images)
                    {
                        <div class="col-md-6 col-lg-4">
                            <div class="card h-100">
                                <img src="@img.ImageUrl" class="card-img-top" alt="Submission image @img.Order" style="object-fit: cover;max-height: 220px;" />
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span class="text-muted small">Order</span>
                                        <span class="badge text-bg-secondary">@img.Order</span>
                                    </div>
                                    <div class="mt-2 text-break small">
                                        <a href="@img.ImageUrl" target="_blank" rel="noreferrer">@img.ImageUrl</a>
                                    </div>
                                    <button type="button" class="btn btn-sm btn-outline-danger mt-2" data-bs-toggle="modal" data-bs-target="#confirmDeleteImageModal" data-submission-id="@Model.Id" data-image-id="@img.Id">Delete</button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
    <div class="mt-3">
        <a href="/challenges/@Model.ChallengeId" class="btn btn-link">← Back to Challenge</a>
    </div>
    <!-- Delete image modal -->
    <div class="modal fade" id="confirmDeleteImageModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Delete image?</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">This will remove the image from the submission.</div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <form method="post" id="deleteImageForm" class="m-0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger">Delete</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
    <!-- Delete submission modal -->
    <div class="modal fade" id="confirmDeleteSubmissionModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Delete submission?</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">This will permanently delete the submission. This is only allowed if it has no images.</div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <form method="post" id="deleteSubmissionForm" class="m-0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger">Delete</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts
{
    <script>
        const deleteImageModal = document.getElementById('confirmDeleteImageModal');
        deleteImageModal?.addEventListener('show.bs.modal', event => {
            const button = event.relatedTarget;
            const submissionId = button.getAttribute('data-submission-id');
            const imageId = button.getAttribute('data-image-id');

            document.getElementById('deleteImageForm').action = `/submissions/${submissionId}/images/${imageId}/delete`;
        });

        const delSubModal = document.getElementById('confirmDeleteSubmissionModal');
        delSubModal?.addEventListener('show.bs.modal', event => {
            const button = event.relatedTarget;
            const id = button.getAttribute('data-submission-id');
            document.getElementById('deleteSubmissionForm').action = `/submissions/${id}/delete`;
        });
    </script>
}