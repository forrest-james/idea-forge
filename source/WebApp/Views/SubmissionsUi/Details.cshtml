@model WebApp.ViewModels.Submissions.SubmissionDetailsVm
@{
    ViewData["Title"] = "Submission for " + Model.ChallengeName;
}

<div class="container py-4">
    <div class="d-flex align-items-start justify-content-between mb-3">
        <div>
            <h1 class="h3 mb-1">Submission for @Model.ChallengeName</h1>
            <div class="text-muted small">@Model.Id</div>
            <div class="mt-2">
                <span class="text-muted">Challenge:</span>
                <a href="/challenges/@Model.ChallengeId" class="link-primary fw-semibold">@Model.ChallengeName</a>
            </div>
        </div>
        <div class="d-flex gap-2">
            <form method="post" action="/submissions/@Model.Id/images" enctype="multipart/form-data" class="d-flex gap-2">
                @Html.AntiForgeryToken()
                <input type="file" name="files" multiple accept=".jpg,.jpeg,.png,.webp" class="form-control" />
                <button type="submit" class="btn btn-primary">Upload</button>
            </form>
        </div>
    </div>
    <div class="card mb-3">
        <div class="card-header">Description</div>
        <div class="card-body">
            @if (string.IsNullOrWhiteSpace(Model.Description))
            {
                <div class="text-muted">No description provided.</div>
            }
            else
            {
                <p class="mb-0">@Model.Description</p>
            }
        </div>
    </div>
    <div class="card">
        <div class="card-header">Images (@Model.Images.Count)</div>
        <div class="card-body">
            @if (Model.Images.Count == 0)
            {
                <div class="text-muted">No images yet.</div>
            }
            else
            {
                <div class="row g-3">
                    @foreach (var img in Model.Images)
                    {
                        <div class="col-md-6 col-lg-4">
                            <div class="card h-100">
                                <img src="@img.ImageUrl" class="card-img-top" alt="Submission image @img.Order" style="object-fit: cover;max-height: 220px;" />
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span class="text-muted small">Order</span>
                                        <span class="badge text-bg-secondary">@img.Order</span>
                                    </div>
                                    <div class="mt-2 text-break small">
                                        <a href="@img.ImageUrl" target="_blank" rel="noreferrer">@img.ImageUrl</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
    <div class="mt-3">
        <a href="/challenges/@Model.ChallengeId" class="btn btn-link">← Back to Challenge</a>
    </div>
</div>
