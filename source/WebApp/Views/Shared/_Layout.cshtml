@using System.Security.Claims
@using Data.Identity
<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebApp</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebApp.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-dark border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="ChallengesUi" asp-action="Index" style="color:#F29800">IdeaForge</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-area="" asp-controller="ChallengesUi" asp-action="Index">Challenges</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-area="" asp-controller="PalettesUi" asp-action="Index">Palettes</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-area="" asp-controller="AppIdeasUi" asp-action="Index">App Ideas</a>
                        </li>
                        @if (User.IsInRole(Roles.Admin))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-light" asp-area="" asp-controller="UsersUi" asp-action="Index">Users</a>
                                </li>
                            }
                    </ul>
                    <ul class="navbar-nav ms-auto">
                        <li>
                            @if (User?.Identity?.IsAuthenticated ?? false)
                            {
                                var username = User.Identity?.Name ?? "User";
                                string role =
                                    User.IsInRole(Roles.Admin) ? Roles.Admin :
                                    User.IsInRole(Roles.Standard) ? Roles.Standard :
                                    User.IsInRole(Roles.Test) ? Roles.Test :
                                    "User";
                                string roleClass = 
                                    role == Roles.Admin ? "text-bg-warning" :
                                    role == Roles.Standard ? "text-bg-primary" :
                                    role == Roles.Test ? "text-bg-secondary" :
                                    "text-bg-secondary";
                                <div class="d-flex align-items-center gap-3">                                    
                                    <div class="d-flex flex-column  lh-1">
                                        <span class="text-light small fw-semibold">@username</span>
                                        <span class="badge @roleClass align-self-start mt-1">@role</span>
                                    </div>                                
                                    <form method="post" action="/account/logout" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="nav-link btn btn-link p-0 text-light">Logout</button>
                                    </form>
                                </div>
                            }
                            else
                            {
                                <a class="nav-link text-light" href="/account/login">Login</a>
                            }
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - IdeaForge
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
